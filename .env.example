# Database
POSTGRES_USER=agentshield
POSTGRES_PASSWORD=change-me
POSTGRES_DB=agentshield_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379
REDIS_ALLOW_FAKE=0

# Server
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# Speech-to-text
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# LLM provider: openai or groq
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
GROQ_API_KEY=

# RAG
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3
CONVERSATION_MEMORY_SECONDS=90
